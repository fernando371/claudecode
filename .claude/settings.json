{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-bash-no-verify.sh" }]
      },
      {
        "matcher": "Agent|Glob|Grep",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-scope-warn.sh" }]
      },
      {
        "matcher": "Agent|Bash|Glob",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-cost-warn.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  }
}
